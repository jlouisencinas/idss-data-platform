# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
# .env is gitignored — never commit real credentials
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloud Run — Gmail OAuth2 token ───────────────────────────────────────────
# Paste the full contents of your local token.json here (single line, JSON string)
# Obtain by running: python main.py  (first time, approves browser OAuth)
GMAIL_TOKEN_JSON={"token": "ya29.xxx", "refresh_token": "1//xxx", "token_uri": "https://oauth2.googleapis.com/token", "client_id": "xxx.apps.googleusercontent.com", "client_secret": "xxx", "scopes": ["https://www.googleapis.com/auth/gmail.readonly"]}

# ── Cloud Run — Google Drive Service Account ──────────────────────────────────
# Paste the full contents of your service_account.json here (single line)
# Create at: console.cloud.google.com → IAM → Service Accounts → Keys
# Share your Drive folder with the service account email address
SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "your-project", "private_key_id": "xxx", "private_key": "-----BEGIN RSA PRIVATE KEY-----\nxxx\n-----END RSA PRIVATE KEY-----\n", "client_email": "idss-pipeline@your-project.iam.gserviceaccount.com", "client_id": "xxx", "auth_uri": "https://accounts.google.com/o/oauth2/auth", "token_uri": "https://oauth2.googleapis.com/token"}

# ── Google Drive folder ID ────────────────────────────────────────────────────
# The folder ID from the Drive URL: drive.google.com/drive/folders/<FOLDER_ID>
DRIVE_FOLDER_ID=1O00CGI9zSzsbGK4S_n3bTAehJ-TUcvrX

# ── Google Apps Script Web App URL ────────────────────────────────────────────
# Format: https://script.google.com/macros/s/<DEPLOYMENT_ID>/exec
#
# ⚠️  DEPLOYMENT ID MANAGEMENT — read this before redeploying:
#
#   Option A (recommended — ID never changes):
#     In Apps Script → top-right Deploy button → Manage Deployments
#     → click the pencil (Edit) on the EXISTING deployment
#     → change "Version" to the latest → click Deploy
#     → Same URL, nothing to update here or in GitHub.
#
#   Option B (new deployment created — ID changes):
#     → Update WEBAPP_URL in this file (.env)
#     → Update the WEBAPP_URL secret in GitHub:
#        Repository → Settings → Secrets and variables → Actions → WEBAPP_URL
#
WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID_HERE/exec

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The spreadsheet ID from the URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
# ⚠️  Share the sheet with your service account email (Editor access).
#     Find the email in SERVICE_ACCOUNT_JSON under "client_email".
SPREADSHEET_ID=your_spreadsheet_id_here

# ── PRISM Portal ──────────────────────────────────────────────────────────────
# Credentials for https://prism.prulifeuk.com.ph
PRISM_USERNAME=70008940
PRISM_PASSWORD=your_prism_password_here

# Gmail OAuth2 token for the plukfloroespiritu account (receives OTP emails).
# Generate once locally: python scripts/generate_prism_otp_token.py
# Then paste the single-line JSON output here and add as GitHub Secret.
PRISM_OTP_TOKEN_JSON={"token": "ya29.xxx", "refresh_token": "1//xxx", "token_uri": "https://oauth2.googleapis.com/token", "client_id": "xxx.apps.googleusercontent.com", "client_secret": "xxx", "scopes": ["https://www.googleapis.com/auth/gmail.readonly"]}

# ── Anthropic API (optional — enables --ai flag) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxx
