# ─── Credentials & tokens — NEVER commit these ───────────────────────────────
credentials*.json
token*.json
drive_token.json
client_secrets.json
service_account.json
prism_otp_token.json
*.p12
*.pem

# ─── Environment variables ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Virtual environment ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ─── Data (downloads, outputs, temp) — generated at runtime ──────────────────
data/downloads/
data/output/
data/temp/

# Keep the directory structure in git
!data/downloads/branch/.gitkeep
!data/downloads/unit/.gitkeep
!data/output/.gitkeep
!data/temp/.gitkeep

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/*.log
logs/*.txt
!logs/.gitkeep

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/
.coverage
htmlcov/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
